# ==========================================
# CRIB PROJECTS - UNIFIED .GITIGNORE
# ==========================================

# --- System / OS ---
.DS_Store
Thumbs.db
*.swp
*~
.nfs*

# --- IDE / Editor ---
.vscode/
.idea/
*.iml
.cursor/
*.code-workspace

# --- Environment & Sensitive Files ---
# Global ignore for environment files
.env
.env.*
*.jks
*.keystore
auth.json
**/google-services.json
**/GoogleService-Info.plist

# --- Root Backups & Archives ---
backend.zip
chatdb/Archive.zip
*.log

# --- Laravel / Backend (Entire Directory Ignored as Requested) ---
/backend/
/backend/.env
/backend/.env.bak
/backend/.env.example
/backend/vendor/
/backend/storage/
/backend/node_modules/
/backend/.phpunit.result.cache

# --- Node.js / ChatDB ---
/chatdb/node_modules/
/chatdb/.env
/chatdb/*.log

# --- Flutter / Dart Ecosystem ---
.dart_tool/
build/
.flutter-plugins
.flutter-plugins-dependencies
.packages
.pub-cache/
.pub-proxy-settings
**/*.g.dart

# Project specific Flutter paths
/cribs_arena/build/
/cribs_arena/.dart_tool/
/cribs_agents/build/
/cribs_agents/.dart_tool/

# --- Android Specific ---
.gradle/
local.properties

# --- iOS Specific ---
ios/.generated/
DerivedData/

# --- References & Credentials ---
# Ignoring the entire reference folder as it contains sensitive service account keys
/reference/
