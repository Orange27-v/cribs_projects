# ==========================================
# CRIB PROJECTS - UNIFIED .GITIGNORE
# ==========================================

# --- System / OS ---
.DS_Store
Thumbs.db
*.swp
*~
.nfs*
*.hprof

# --- IDE / Editor ---
.vscode/
.idea/
*.iml
.cursor/
.agent/
!.agent/workflows/
.gemini/
*.code-workspace

# --- Environment & Sensitive Files ---
# Global ignore for environment files
.env
.env.*
**/google-services.json
**/GoogleService-Info.plist

# Sensitive Credentials & Certificates
password.md
*.pem
*.key
*.crt
*.p12
*.jks
*.keystore
auth.json

# --- Root Backups & Archives ---
backend.zip
chatdb/Archive.zip
*.log

# --- Laravel / Backend ---
# Removing 'backend/' ignore rule to allow tracking of backend source code
/backend/.env
/backend/.env.bak
/backend/.env.example
/backend/vendor/
/backend/vendor.zip
/backend/storage/
/backend/node_modules/
/backend/.phpunit.result.cache

# --- Node.js / ChatDB ---
/chatdb/node_modules/
/chatdb/.env
/chatdb/*.log

# --- Flutter / Dart Ecosystem ---
.dart_tool/
build/
.flutter-plugins
.flutter-plugins-dependencies
.packages
.pub-cache/
.pub-proxy-settings
**/*.g.dart

# Project specific Flutter paths
/cribs_arena/build/
/cribs_arena/.dart_tool/
/cribs_agents/build/
/cribs_agents/.dart_tool/

# --- Android Specific ---
.gradle/
local.properties
**/android/local.properties
**/android/.gradle/
**/android/captures/
**/android/app/google-services.json

# --- iOS Specific ---
ios/.generated/
DerivedData/
**/ios/Pods/
**/ios/.generated/
**/ios/DerivedData/
**/ios/Runner/GoogleService-Info.plist
Icon?

